# OpenRouter — used as a unified gateway to coding LLMs.
# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model. qwen/qwen3-coder is the recommended cheap-but-accurate coding model.
# You can swap to any OpenRouter model (deepseek/deepseek-chat-v3.1, anthropic/claude-haiku-4-5, ...).
OPENROUTER_MODEL=qwen/qwen3-coder

# Telegram — talk to @BotFather to create a bot and get this token.
# Only required when running the bot in --telegram mode. CLI mode works without it.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
